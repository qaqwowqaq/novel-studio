{
  "name": "novel-studio",
  "productName": "Novel Studio",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "卷灯 · 本地优先的长篇小说写作软件 (Novel Studio)",
  "author": {
    "name": "Novel Studio contributors",
    "email": "guanda.chenn@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/qaqwowqaq/novel-studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/qaqwowqaq/novel-studio.git"
  },
  "bugs": {
    "url": "https://github.com/qaqwowqaq/novel-studio/issues"
  },
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:desktop\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "dev:desktop": "wait-on tcp:4173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:4173 electron .",
    "build": "tsc -b && vite build",
    "repair:electron": "node scripts/repair-electron-cache.mjs",
    "start": "electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "icon:transparent": "node scripts/make-transparent-icon.mjs",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.juandeng.novel-studio",
    "productName": "Novel Studio",
    "copyright": "Copyright © 2026 Novel Studio contributors",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "qaqwowqaq",
        "repo": "novel-studio"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Novel-Studio-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "卷灯"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "Novel-Studio-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "artifactName": "Novel-Studio-${version}-${arch}.${ext}"
    }
  }
}
